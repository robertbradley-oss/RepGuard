# ClaimGuard Phase 4.38 safe example configuration.
# This file is example only and contains no secrets or real provider values.
# Provider calls and API-credit usage require separate Robert approval before use.
# The current sandbox works without provider configuration.
# Do not use real evidence, customer identifiers, provider payloads, or raw OCR here.

CLAIMGUARD_VISION_PROVIDER_ENABLED=false
CLAIMGUARD_VISION_PROVIDER_CALLS_ALLOWED=false
CLAIMGUARD_VISION_REQUEST_EXECUTION_ALLOWED=false
CLAIMGUARD_VISION_API_CREDIT_USAGE_ALLOWED=false

CLAIMGUARD_VISION_PROVIDER_MODE=sandbox
CLAIMGUARD_VISION_PROVIDER_FAMILY=openai-vision-style
CLAIMGUARD_VISION_PROVIDER_MODEL=not-configured
CLAIMGUARD_VISION_PROVIDER_API_KEY=

CLAIMGUARD_VISION_EVIDENCE_SCOPE=synthetic-fixture-only
CLAIMGUARD_VISION_PAYLOAD_LOGGING_POLICY=disabled
CLAIMGUARD_VISION_RAW_OCR_RETENTION_POLICY=disabled
CLAIMGUARD_VISION_PACKAGE_SAFETY_MODE=downloadable-safe-disabled
